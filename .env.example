# Public site URL for canonical links, OG tags, sitemap (no trailing slash)
# VITE_SITE_URL=https://barakali.uz

# MapTiler — https://cloud.maptiler.com/account/keys/
VITE_MAPTILER_API_KEY=

# Google reCAPTCHA — https://www.google.com/recaptcha/admin
# v2 = checkbox widget, v3 = invisible score-based (default)
VITE_RECAPTCHA_VERSION=v3
VITE_RECAPTCHA_SITE_KEY=
VITE_RECAPTCHA_SECRET_KEY=
# Set to true to skip captcha locally without configuring Google console domains
# VITE_RECAPTCHA_DEV_BYPASS=true
